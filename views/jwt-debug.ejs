<!DOCTYPE html>
<html>
<head>
    <title>JWT Debugger</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <h2>JWT Token Debugger</h2>
        
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">Login to Get Token</div>
                    <div class="card-body">
                        <input type="email" id="email" class="form-control mb-2" value="librarian@library.com">
                        <input type="password" id="password" class="form-control mb-2" value="password123">
                        <button class="btn btn-primary" onclick="login()">Login & Get Token</button>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">Your JWT Token</div>
                    <div class="card-body">
                        <textarea id="token" class="form-control" rows="3" readonly></textarea>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">Decoded Token</div>
                    <div class="card-body">
                        <pre id="decoded" style="background: #f4f4f4; padding: 15px;"></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function login() {
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            
            const res = await fetch('/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password })
            });
            
            const data = await res.json();
            
            if (data.success) {
                document.getElementById('token').value = data.token;
                
                // Decode token
                const parts = data.token.split('.');
                const header = JSON.parse(atob(parts[0]));
                const payload = JSON.parse(atob(parts[1]));
                
                document.getElementById('decoded').textContent = 
                    'HEADER:\n' + JSON.stringify(header, null, 2) + 
                    '\n\nPAYLOAD:\n' + JSON.stringify(payload, null, 2) +
                    '\n\nEXPIRY: ' + new Date(payload.exp * 1000).toLocaleString();
            }
        }
    </script>
</body>
</html>