<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-box-arrow-in-right"></i> Login</h4>
            </div>
            <div class="card-body">
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                
                <% if (req.query.registered) { %>
                    <div class="alert alert-success">
                        Registration successful! Please login.
                    </div>
                <% } %>
                
                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email address</label>
                        <input type="email" class="form-control" id="email" name="email" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" id="password" name="password" required>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </button>
                </form>
                <!-- Add this after the login button or before register link -->
<div class="text-center mt-2">
    <a href="/forgot-password" class="text-decoration-none" style="font-size: 0.9rem;">
        <i class="bi bi-question-circle"></i> Forgot Password?
    </a>
</div>
                <div class="text-center mt-3">
                    <p>Don't have an account? <a href="/register">Register here</a></p>
                </div>
                
                <hr>
                <!-- <div class="text-center text-muted small">
                    <p class="mb-1"><strong>Demo Credentials:</strong></p>
                    <p class="mb-1">Librarian: librarian@library.com / password123</p>
                    <p class="mb-0">Member: member@library.com / password123</p>
                </div> -->
            </div>
        </div>
    </div>
</div>