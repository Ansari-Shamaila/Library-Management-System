<div class="row mb-4">
    <div class="col">
        <h2><i class="bi bi-collection"></i> Books</h2>
    </div>
</div>

<!-- Show flash messages -->
<% if (req && req.flash) { %>
    <% const error = req.flash('error'); %>
    <% if (error && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> <%= error[0] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
    
    <% const success = req.flash('success'); %>
    <% if (success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> <%= success[0] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>
<% } %>

<!-- Library Stats -->
<div class="library-stats row mb-4">
    <div class="col-md-4 stat-item">
        <i class="bi bi-book"></i>
        <div class="stat-number"><%= books ? books.length : 0 %></div>
        <div class="stat-label">Total Books</div>
    </div>
    <div class="col-md-4 stat-item">
        <i class="bi bi-bookmark-check"></i>
        <div class="stat-number">
            <% 
                let available = 0;
                if(books) {
                    books.forEach(b => { available += b.available_copies });
                }
            %>
            <%= available %>
        </div>
        <div class="stat-label">Available Copies</div>
    </div>
    <div class="col-md-4 stat-item">
        <i class="bi bi-tags"></i>
        <div class="stat-number">
            <% 
                let categories = [];
                if(books) {
                    books.forEach(b => { if(!categories.includes(b.category)) categories.push(b.category); });
                }
            %>
            <%= categories.length %>
        </div>
        <div class="stat-label">Categories</div>
    </div>
</div>

<% if (typeof message !== 'undefined' && message) { %>
    <div class="alert alert-info"><%= message %></div>
<% } %>

<div class="row">
    <% if (books && books.length > 0) { %>
        <% books.forEach((book, index) => { 
            // Different colors for different books (cycle through 5 colors)
            const coverClass = 'book-cover-' + ((index % 5) + 1);
            // ✅ CHECK IF USER HAS ALREADY BORROWED THIS BOOK
            const isAlreadyBorrowed = userBorrowedBooks && userBorrowedBooks.includes(book.id);
        %>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <!-- Book Image/Icon -->
                    <div class="book-image-container <%= coverClass %>">
                        <i class="bi bi-journal-bookmark-fill"></i>
                        <span class="book-category-badge">
                            <i class="bi bi-tag"></i> <%= book.category || 'General' %>
                        </span>
                    </div>
                    
                    <div class="card-body">
                        <h5 class="card-title"><%= book.title || 'Untitled' %></h5>
                        <h6 class="card-subtitle mb-2 text-muted">
                            <i class="bi bi-pencil"></i> <%= book.author || 'Unknown' %>
                        </h6>
                        
                        <div class="book-details mt-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span><i class="bi bi-upc-scan text-primary"></i> ISBN:</span>
                                <span class="text-muted"><%= book.isbn ? book.isbn.substring(0,10) + '...' : 'N/A' %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span><i class="bi bi-files text-info"></i> Copies:</span>
                                <span>
                                    <span class="text-success fw-bold"><%= book.available_copies || 0 %></span>
                                    / <%= book.total_copies || 0 %>
                                </span>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <!-- ✅ UPDATED BUTTON LOGIC -->
                            <% if (isAlreadyBorrowed) { %>
                                <button class="btn btn-sm btn-secondary" disabled>
                                    <i class="bi bi-check-circle"></i> Already Borrowed
                                </button>
                            <% } else if (book.available_copies > 0) { %>
                                <form action="/books/borrow/<%= book.id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-book"></i> Borrow
                                    </button>
                                </form>
                            <% } else { %>
                                <button class="btn btn-sm btn-secondary" disabled>
                                    <i class="bi bi-x-circle"></i> Unavailable
                                </button>
                            <% } %>
                            
                            <% if (user && user.role === 'librarian') { %>
                                <div>
                                    <a href="/books/edit/<%= book.id %>" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form action="/books/delete/<%= book.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-danger" 
                                                onclick="return confirm('Are you sure you want to delete this book?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <div class="col">
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle"></i> No books found.
                <% if (user && user.role === 'librarian') { %>
                    <a href="/books/add" class="alert-link"> Add your first book</a>
                <% } %>
            </div>
        </div>
    <% } %>
</div>